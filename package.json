{
  "name": "patorsiang-portfolio-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*",
    "legacy-v1"
  ],
  "scripts": {
    "dev": "bun run dev:portfolio",
    "build": "bun run build:portfolio && bun run build:legacy",
    "lint": "bun run --cwd apps/portfolio-web lint && bun run --cwd legacy-v1 lint",
    "typecheck": "bun run --cwd apps/portfolio-web typecheck && bun run --cwd legacy-v1 typecheck",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "dev:portfolio": "bun run --cwd apps/portfolio-web dev",
    "build:portfolio": "bun run --cwd apps/portfolio-web build",
    "dev:legacy": "bun run --cwd legacy-v1 dev",
    "build:legacy": "bun run --cwd legacy-v1 build",
    "lint:legacy": "bun run --cwd legacy-v1 lint",
    "typecheck:legacy": "bun run --cwd legacy-v1 typecheck"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4"
  }
}
